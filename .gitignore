# ─────────────────────────────────────────────────────────────────────────────
# SECRETS — never commit these
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─────────────────────────────────────────────────────────────────────────────
# macOS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverrideIcon
._*

# ─────────────────────────────────────────────────────────────────────────────
# EDITORS
# ─────────────────────────────────────────────────────────────────────────────

# VS Code — keep .vscode/extensions.json and .vscode/settings.json if you want
# to share editor config, but ignore personal/local overrides
.vscode/launch.json
.vscode/*.code-workspace

# JetBrains (GoLand, PyCharm, WebStorm)
.idea/
*.iml

# ─────────────────────────────────────────────────────────────────────────────
# GO BACKEND
# ─────────────────────────────────────────────────────────────────────────────
bin/
backend/*.exe
backend/*.test

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON AI SERVICE
# ─────────────────────────────────────────────────────────────────────────────
ai-service/.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─────────────────────────────────────────────────────────────────────────────
# JAVASCRIPT / TYPESCRIPT (web + mobile + shared)
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
bun.lockb
*.tsbuildinfo

# Vite web build output
frontend-web/dist/

# Expo / React Native
frontend-mobile/.expo/
frontend-mobile/dist/

# ─────────────────────────────────────────────────────────────────────────────
# PROTOBUF — generated stubs are derived from proto/ source files
# ─────────────────────────────────────────────────────────────────────────────
backend/pb/
ai-service/pb/

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────────────────────────────────────
.docker/

# ─────────────────────────────────────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────────────────────────────────────
*.log
logs/
