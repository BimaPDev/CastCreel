{
  "expo": {
    "name": "CastCreel",
    "slug": "castcreel",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.castcreel.app",
      "infoPlist": {
        "NSCameraUsageDescription": "CastCreel needs camera access to photograph your catch for species identification.",
        "NSLocationWhenInUseUsageDescription": "CastCreel uses your location to record where you caught fish and to show nearby wildlife events.",
        "NSLocationAlwaysUsageDescription": "CastCreel uses your location to alert you about stocking events near your saved fishing spots."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.castcreel.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CastCreel uses your location to record catches and alert you about nearby stocking events."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "scheme": "castcreel",
    "experiments": {
      "typedRoutes": true
    }
  }
}
